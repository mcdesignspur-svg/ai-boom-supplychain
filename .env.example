# ── Live stock quotes (optional) ─────────────────────────────────────────────
# The app works WITHOUT any key: it renders reference data with a gentle
# simulated drift and labels everything as "datos de referencia · simulado".
#
# Provide a Finnhub API key to pull REAL prices for the US-listed tickers
# (NASDAQ / NYSE — the "liquid" companies). OTC tickers have no reliable free
# coverage and always fall back to reference data, clearly marked in the UI.
#
# Get a free key at https://finnhub.io/  (free tier: 60 requests/min)
FINNHUB_API_KEY=

# How long (seconds) the server caches a quotes snapshot before refetching.
# Keep this >= 15 to stay well within free-tier limits. Default: 30.
QUOTES_REVALIDATE_SECONDS=30
